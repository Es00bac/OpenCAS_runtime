{
  "manifest_version": 1,
  "id": "desktop_context",
  "name": "Desktop Context",
  "description": "Toggleable body-double skill that captures the active desktop, creates context from screenshots/OCR/vision analysis, and can speak short local TTS nudges when useful.",
  "version": "1.0.0",
  "entrypoint": "main.py",
  "config_schema": {
    "type": "object",
    "properties": {
      "enabled": {"type": "boolean"},
      "capture_interval_seconds": {"type": "integer"},
      "min_speech_interval_seconds": {"type": "integer"},
      "tts_enabled": {"type": "boolean"},
      "play_audio": {"type": "boolean"},
      "vision_enabled": {"type": "boolean"},
      "ocr_enabled": {"type": "boolean"},
      "capture_backend": {"type": "string"},
      "vision_model": {"type": "string"},
      "session_id": {"type": "string"},
      "max_image_bytes": {"type": "integer"},
      "vision_max_dimension": {"type": "integer"},
      "vision_jpeg_quality": {"type": "integer"}
    }
  },
  "default_config": {
    "enabled": false,
    "capture_interval_seconds": 300,
    "min_speech_interval_seconds": 60,
    "tts_enabled": true,
    "play_audio": true,
    "vision_enabled": true,
    "ocr_enabled": true,
    "capture_backend": "auto",
    "max_image_bytes": 5000000,
    "vision_max_dimension": 1600,
    "vision_jpeg_quality": 82
  },
  "capabilities": [
    {
      "capability_id": "plugin:desktop_context.observe",
      "display_name": "Desktop Context Observation",
      "kind": "tool",
      "description": "Capture the active desktop and decide whether a short collaborative comment should be spoken.",
      "tool_names": [
        "desktop_context_status",
        "desktop_context_configure",
        "desktop_context_capture",
        "desktop_context_observe",
        "desktop_context_speak"
      ]
    }
  ]
}
